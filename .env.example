# =============================================================
# Marine Management System — Environment Variables Template
# =============================================================
# Bu dosyayı kopyalayıp ".env" olarak kaydedin, gerçek değerleri girin.
# .env dosyası ASLA git'e commit edilmemeli (zaten .gitignore'da).
#
# Kullanım: cp .env.example .env
# =============================================================

# ─── VERİTABANI ──────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/marine_management
DATABASE_USERNAME=marine_user
# Güçlü, rastgele bir şifre kullanın. Örnek: openssl rand -base64 32
DATABASE_PASSWORD=

# ─── JWT GÜVENLİK ─────────────────────────────────────────────
# En az 256-bit rastgele üretin: openssl rand -hex 32
JWT_SECRET=
# Token süresi (ms): 900000 = 15 dakika (önerilen), 3600000 = 1 saat
JWT_EXPIRATION=900000
# Refresh token süresi (ms): 604800000 = 7 gün
REFRESH_TOKEN_EXPIRATION=604800000

# ─── SİSTEM ADMİN ─────────────────────────────────────────────
SYSTEM_ADMIN_USERNAME=superadmin
SYSTEM_ADMIN_EMAIL=superadmin@your-domain.com
# İlk girişte hemen değiştirin!
SYSTEM_ADMIN_PASSWORD=

# ─── CORS ─────────────────────────────────────────────────────
# Wildcard (*) KULLANMAYIN — sadece gerçek frontend URL'i
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# ─── E-POSTA (Gmail SMTP) ─────────────────────────────────────
MAIL_ENABLED=false
MAIL_USERNAME=your-gmail@gmail.com
# Gmail → Güvenlik → Uygulama Şifreleri'nden üretin (hesap şifresi değil)
MAIL_PASSWORD=
MAIL_FROM=noreply@your-domain.com

# E-posta bağlantı URL'leri (frontend domain ile eşleşmeli)
APP_VERIFY_URL=https://your-frontend-domain.com/verify-email
APP_RESET_PASSWORD_URL=https://your-frontend-domain.com/reset-password

# ─── CLOUDFLARE R2 (Dosya Depolama) ───────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=marine-attachments
# Pre-signed URL geçerlilik süresi (dakika)
R2_PRESIGNED_URL_EXPIRY=60

# ─── SUNUCU ───────────────────────────────────────────────────
SERVER_PORT=8080

# ─── VERİTABANI BAĞLANTI HAVUZU ───────────────────────────────
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=10
